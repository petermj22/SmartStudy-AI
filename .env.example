# ============================================================
# SmartStudy - Environment Configuration
# Copy this file to .env and update values
# ============================================================

# Application
APP_NAME=SmartStudy
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=false

# Database
DATABASE_PATH=data/smartstudy.db
DATABASE_ECHO=false

# Camera
DEFAULT_CAMERA_ID=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# ML Models
MODELS_DIR=ml_training/trained_models
ENSEMBLE_MODEL_VERSION=v1.0
LSTM_MODEL_VERSION=v1.0

# Performance
FRAME_SKIP=1
SMOOTHING_WINDOW=15
MAX_INFERENCE_MS=100

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Features
ENABLE_SOUND_ALERTS=true
ENABLE_CALIBRATION=true
